# ---------------------------------------------------------------------------
# Company RAG Chatbot — backend environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- App ---
APP_NAME="Company RAG Chatbot"
ENVIRONMENT=development
DEBUG=true

# --- API ---
API_V1_PREFIX=/api
# Comma-separated list of allowed frontend origins (Vite dev server below).
CORS_ORIGINS=http://localhost:5173

# --- LLM: Mistral API ---
# Get a free API key at https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# --- Embeddings (runs locally, no key required) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Ingestion / chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval / chat ---
# Chunks retrieved per question.
TOP_K_RESULTS=4
# Min cosine similarity for a chunk to count as relevant. If the best match is
# below this, a polite fallback is returned without calling the LLM (0.0-1.0).
SIMILARITY_THRESHOLD=0.3

# --- Storage paths (relative to the backend/ directory) ---
DATABASE_URL=sqlite:///./data/app.db
VECTORSTORE_PATH=./data/vectorstore
UPLOAD_DIR=./data/uploads
